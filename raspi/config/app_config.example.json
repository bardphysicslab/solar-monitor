{
  "app_id": "solar-monitor",
  "mode": "sensor_monitor",
  "poll_interval_ms": 1500,
  "title": "Solar Monitor",
  "drivers": [
    {
      "driver": "wifi_node",
      "uid": "bb-solar-pnl-001",
      "config": {
        "host": "REPLACE_WITH_ESP32_IP",
        "port": 1234,
        "timeout_s": 3
      }
    },
    {
      "driver": "spn1",
      "uid": "spn1-0001",
      "config": {
        "port": "/dev/cu.PL2303G-USBtoUART1130",
        "baud": 9600,
        "auto_sync_time": true,
        "sync_interval_hours": 24
      }
    }
  ]
}
